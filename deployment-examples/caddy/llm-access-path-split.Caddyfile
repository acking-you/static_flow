ackingliu.top, www.ackingliu.top, staticflow.cc, www.staticflow.cc {
        @health path /_caddy_health
        respond @health "ok" 200

        @admin path /admin*
        respond @admin "forbidden" 403

	# In this path-split topology every image path is steered to the
	# standalone image gateway (:19082), which gates on the per-key
	# `codex_image_generation_enabled` switch. The main llm-access binary
	# (:19080) also serves these paths in its integrated "direct" mode
	# (gated by `codex_image_direct_generation_enabled`), but that path is
	# only reached on deployments that do NOT front images with this block.
	# Keep this matcher ordered before @llm_access (asserted by
	# scripts/test_llm_access_cloud_bundle.sh).
	@codex_image path /v1/images/generations /v1/images/edits /api/codex-gateway/images/generations /api/codex-gateway/images/edits /api/codex-gateway/v1/images/generations /api/codex-gateway/v1/images/edits /api/llm-gateway/v1/images/generations /api/llm-gateway/v1/images/edits
	handle @codex_image {
		reverse_proxy 127.0.0.1:19082 {
			transport http {
				dial_timeout 10s
				response_header_timeout 15m
				read_timeout 15m
				write_timeout 15m
			}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
			header_up X-Forwarded-Host {host}
		}
        }

	@llm_access path /v1/* /cc/v1/* /api/llm-gateway/* /api/kiro-gateway/* /api/codex-gateway/* /api/llm-access/*
	handle @llm_access {
		reverse_proxy 127.0.0.1:19080 {
			# LLM requests can legitimately stream or wait on upstreams for several
			# minutes, so keep origin-side read/write/header timeouts generous and
			# disable proxy buffering for SSE-style responses.
			flush_interval -1
			transport http {
				dial_timeout 10s
				response_header_timeout 15m
				read_timeout 15m
				write_timeout 15m
			}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
			header_up X-Forwarded-Host {host}
		}
        }

	handle {
		reverse_proxy 127.0.0.1:39080 {
			# Keep the non-LLM relay path aligned with the longer origin timeout so
			# large page generations or relay-backed responses do not get cut short
			# by Caddy once Cloudflare proxying is disabled.
			transport http {
				dial_timeout 10s
				response_header_timeout 15m
				read_timeout 15m
				write_timeout 15m
			}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
			header_up X-Forwarded-Host {host}
		}
        }
}
